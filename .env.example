YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REDIRECT_URI=http://localhost:3000/auth/youtube/callback

FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://localhost:3443/auth/facebook/callback

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/auth/twitch/callback

PORT=3000
RTMP_PORT=1935
LOCAL_STREAM_KEY=multistream-live
FB_API_VERSION=v25.0

# App auth (leave empty to disable auth — local dev mode)
APP_SECRET=

# Set ONLY when running behind a reverse proxy (nginx, Cloudflare, tunnel) so the login rate
# limiter keys on the real client IP. Leave empty otherwise — enabling it without a proxy lets
# clients spoof their IP. Accepts 'true', a hop count (e.g. 1), or a subnet/IP.
TRUST_PROXY=
