YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REDIRECT_URI=http://localhost:3000/auth/youtube/callback

FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://localhost:3443/auth/facebook/callback

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:3000/auth/twitch/callback

PORT=3000
HTTPS_PORT=3443
RTMP_PORT=1935
LOCAL_STREAM_KEY=multistream-live
FB_API_VERSION=v25.0

# Web Studio ingest video encoder: auto | nvenc | libx264 (default: auto).
# auto = use NVIDIA NVENC (GPU) if this ffmpeg build supports it, else libx264 (CPU).
# nvenc forces the GPU but still falls back to libx264 if unavailable, so streaming never breaks.
STUDIO_VIDEO_ENCODER=auto

# Encode preset (speed vs quality) for whichever encoder is active. Defaults are sensible; an
# invalid value falls back to the default. NVENC: p1 (fastest)…p7 (best), or named (hq, ll).
# libx264: ultrafast…veryslow/placebo.
STUDIO_NVENC_PRESET=p5
STUDIO_X264_PRESET=veryfast

# App auth (leave empty to disable auth — local dev mode)
APP_SECRET=

# Behind a reverse proxy / Cloudflare Tunnel (the default deployment), set this to true so the
# login rate limiter keys on the real client IP (Cloudflare's CF-Connecting-IP) instead of every
# visitor collapsing to the tunnel's localhost address. Set to false/empty ONLY if the app is
# reached directly with nothing in front — trusting headers without a proxy lets clients spoof
# their IP. Accepts true, a hop count (e.g. 1), or a subnet/IP.
TRUST_PROXY=true

# Web Studio re-encode quality (kbps). Total upload ≈ video bitrate × number of platforms, so
# lower the video bitrate if the operator's upload bandwidth is constrained.
STUDIO_VIDEO_BITRATE=4500
STUDIO_AUDIO_BITRATE=160

# Optional: paths to a real TLS cert + key (e.g. Let's Encrypt) for a public-domain / DDNS
# deployment. Not needed behind a Cloudflare Tunnel (TLS terminates at Cloudflare). Leave empty
# to use the auto-generated self-signed localhost cert.
TLS_CERT_FILE=
TLS_KEY_FILE=
