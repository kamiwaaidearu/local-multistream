node_modules/
dist/
client/node_modules/
client/dist/
*.tsbuildinfo

# MediaPipe wasm runtime — copied out of node_modules at build time by
# client/scripts/copy-mediapipe-wasm.mjs, not committed. (The .tflite model IS committed.)
client/public/mediapipe/wasm/

# Environment
.env

# Database
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal

# TLS — the auto-generated self-signed localhost cert/key (regenerated on demand by server/cert.ts).
# Never commit a private key; point at a real cert via TLS_CERT_FILE / TLS_KEY_FILE instead.
data/*.key
data/*.cert

# Uploads (keep directory, ignore files)
uploads/*
!uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
