{
  "name": "local-multistream",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "test": "node --import tsx --test server/studio/loginRateLimiter.test.ts server/studio/authCrypto.test.ts && npm --prefix client run test"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "googleapis": "^144.0.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "node-media-server": "^2.7.1",
    "selfsigned": "^5.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
